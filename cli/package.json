{
  "name": "extractvibe",
  "version": "0.1.0",
  "description": "Extract comprehensive brand kits from any website",
  "bin": {
    "extractvibe": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=esm --banner:js=\"#!/usr/bin/env node\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "brand",
    "brand-kit",
    "extraction",
    "colors",
    "typography",
    "design-tokens",
    "vibe"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seangeng/extractvibe"
  },
  "homepage": "https://extractvibe.com",
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "files": [
    "dist/"
  ]
}
