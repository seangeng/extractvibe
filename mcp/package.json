{
  "name": "extractvibe-mcp",
  "version": "0.1.0",
  "description": "MCP server for ExtractVibe — extract brand kits from any website",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "extractvibe-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=esm --banner:js=\"#!/usr/bin/env node\" --external:@modelcontextprotocol/sdk --external:zod",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "model-context-protocol", "brand", "extraction", "design-tokens"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "@types/node": "^22.0.0"
  },
  "files": ["dist/"]
}
